# Copy this file to fly.toml and change the app name:
#   cp fly.toml.example fly.toml
#
# Then edit the "app" and "primary_region" values below.
# Find your nearest region with: fly platform regions

app = 'your-app-name'
primary_region = 'lhr'

[build]

[http_service]
  internal_port = 2222
  force_https = true
  auto_stop_machines = 'stop'
  auto_start_machines = true
  min_machines_running = 0
  processes = ['app']

[[services]]
  protocol = 'tcp'
  internal_port = 2222

  [[services.ports]]
    port = 22

[[vm]]
  memory = '1gb'
  cpu_kind = 'shared'
  cpus = 1
  memory_mb = 1024
